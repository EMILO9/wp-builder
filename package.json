{
	"name": "@emilo/wp-builder",
	"version": "1.0.0",
	"description": "A lightweight CLI and build tool for WordPress development workflows",
	"main": "./dist/lib/lib-m.cjs",
	"module": "./dist/lib/lib-m.mjs",
	"types": "./dist/lib/lib-m.d.cts",
	"scripts": {
		"build": "tsdown",
		"attw": "attw --pack .",
		"test": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"bin": {
		"wp-builder": "dist/cli/cli-m.mjs"
	},
	"exports": {
		".": {
			"import": {
				"default": "./dist/lib/lib-m.mjs",
				"types": "./dist/lib/lib-m.d.mts"
			},
			"require": {
				"default": "./dist/lib/lib-m.cjs",
				"types": "./dist/lib/lib-m.d.cts"
			}
		},
		"./client": {
			"types": "./client.d.ts"
		}
	},
	"keywords": [
		"wordpress",
		"cli",
		"builder",
		"tooling",
		"build-tool",
		"developer-tools",
		"node-cli",
		"automation"
	],
	"files": [
		"dist",
		"client.d.ts"
	],
	"author": "EMILO9",
	"license": "MIT",
	"type": "module",
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^25.6.0",
		"execa": "^9.6.1",
		"tsdown": "^0.21.8",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"change-case": "^5.4.4",
		"commander": "^14.0.3",
		"consola": "^3.4.2",
		"cosmiconfig": "^9.0.1",
		"cosmiconfig-typescript-loader": "^6.3.0",
		"fs-extra": "^11.3.4",
		"handlebars": "^4.7.9",
		"parse-packagejson-name": "^1.1.0",
		"vite": "^8.0.8",
		"zod": "^4.3.6",
		"zod-validation-error": "^5.0.0"
	}
}
